# Nexora AI - Environment Configuration

# Free API Keys Setup

## 1. GROQ API (Free & Fast LLM)
# Get free key: https://console.groq.com
# - Sign up with Google/GitHub
# - Go to API Keys section
# - Create new key
# Paste here:
GROQ_API_KEY=your_groq_api_key_here

## 2. HUGGINGFACE API (Multiple Models)
# Get free key: https://huggingface.co/settings/tokens
# - Create HuggingFace account
# - Go to Settings → Access Tokens
# - Create new token (read)
# Paste here:
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

## 3. BING SEARCH API (Web Search)
# Get free key: https://www.bing.com/webmaster/configure
# - Sign in with Microsoft account
# - Go to Search Console
# - Get API key
# Paste here:
BING_SEARCH_KEY=your_bing_search_key_here

# Optional: Other APIs

## Replicate API (Model hosting)
# https://replicate.com
REPLICATE_API_TOKEN=your_replicate_token_here

## OpenAI API (Optional backup)
# https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

## Supabase (Knowledge base storage)
# https://supabase.com
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://nexora-ai.netlify.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database
DATABASE_URL=./nexora.db

# Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn_here
LOG_ROCKET_ID=your_logrocket_id_here

# Feature Flags
ENABLE_CODE_EXECUTION=true
ENABLE_WEB_SEARCH=true
ENABLE_KNOWLEDGE_BASE=true
ENABLE_VISION=true
